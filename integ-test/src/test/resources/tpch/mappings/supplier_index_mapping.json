      },
      "s_address": {
        "type": "text"
      },
      "s_nationkey": {
        "type": "long"
      },
      "s_phone": {
        "type": "keyword"
      },
      "s_acctbal": {
        "type": "double"
      },
      "s_comment": {
        "type": "text"
      }
    }
  }
}
