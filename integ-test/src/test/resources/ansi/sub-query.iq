# Correlated EXISTS subquery with LEFT JOIN on TRUE condition.
# The correlation variable (deptno) is used in the RHS of the join.
SELECT deptno
FROM dept d
WHERE EXISTS (
    SELECT 1
    FROM emp e
    LEFT JOIN (
        SELECT deptno FROM emp WHERE deptno = deptno
    ) foo
    ON TRUE
    WHERE deptno IS NOT DISTINCT FROM deptno
);
