  (select count(*)
   from emp e
   where deptno = deptno
   and sal > (
     select min(losal)
     from (VALUES (1, 700, 1200), (2, 1201, 1400), (3, 1401, 2000), (4, 2001, 3000), (5, 3001, 9999)) AS s(grade, losal, hisal)
     where sal BETWEEN losal AND hisal
     and hisal > deptno * 10
