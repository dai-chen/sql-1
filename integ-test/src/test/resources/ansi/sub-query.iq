# Two EXISTS
# [CALCITE-1511] AssertionError while decorrelating query with two EXISTS sub-queries
select *
from "scott".dept as d
where exists (select 1 from "scott".emp where empno > deptno)
and exists (select 0 from "scott".emp where deptno = deptno and ename = 'SMITH');
+--------+----------+--------+
| DEPTNO | DNAME    | LOC    |
+--------+----------+--------+
|     20 | RESEARCH | DALLAS |
+--------+----------+--------+
(1 row)

!ok

# Two scalar sub-queries
select deptno,
  (select min(1) from "scott".emp where empno > deptno) as i0,
  (select min(0) from "scott".emp where deptno = deptno and ename = 'SMITH') as i1
from "scott".dept as d;
+--------+----+----+
| DEPTNO | I0 | I1 |
+--------+----+----+
|     10 |  1 |    |
|     20 |  1 |  0 |
|     30 |  1 |    |
|     40 |  1 |    |
+--------+----+----+
(4 rows)

!ok

# Correlated scalar sub-query
SELECT dname,
    (WITH clerks AS
      (SELECT *
       FROM "scott".emp
       WHERE deptno = deptno)
     SELECT min(sal)
     FROM clerks) AS min_clerk_sal
FROM "scott".dept AS d;
+------------+---------------+
| DNAME      | MIN_CLERK_SAL |
+------------+---------------+
| ACCOUNTING |       1300.00 |
| OPERATIONS |               |
| RESEARCH   |        800.00 |
| SALES      |        950.00 |
+------------+---------------+
(4 rows)

!ok

# As previous, minimal
SELECT (WITH t2 AS (SELECT a)
        SELECT a FROM t2) AS c
FROM (SELECT 1 AS a) AS t;
+---+
| C |
+---+
| 1 |
+---+
(1 row)

!ok

# As above, converting CTE to inline view
SELECT (SELECT a
        FROM (SELECT a) AS t2) AS c
FROM (SELECT 1 AS a) AS t;
+---+
| C |
+---+
| 1 |
+---+
(1 row)

!ok

# [CALCITE-6554] nested correlated sub-query in aggregation does not have inner correlation variable bound to inner projection
SELECT ename,
       (SELECT Sum(sal + COALESCE((SELECT Sum(sal) FROM "scott".emp AS subord2
                   WHERE
                           subord2.mgr =
                           empno), 0))
        FROM   "scott".emp AS subord
        WHERE  mgr = empno) AS deep2sal
FROM   "scott".emp AS bosses;
+--------+----------+
| ENAME  | DEEP2SAL |
+--------+----------+
| ADAMS  |          |
| ALLEN  |          |
| BLAKE  |  6550.00 |
| CLARK  |  1300.00 |
| FORD   |   800.00 |
| JAMES  |          |
| JONES  |  7900.00 |
| KING   | 22125.00 |
| MARTIN |          |
| MILLER |          |
| SCOTT  |  1100.00 |
| SMITH  |          |
| TURNER |          |
| WARD   |          |
+--------+----------+
(14 rows)

!ok
# [CALCITE-1494] Inefficient plan for correlated sub-queries
# Plan must have only one scan each of emp and dept.
select sal
from "scott".emp
where empno IN (
  select deptno
  from "scott".dept
  where job = dname);
+-----+
| SAL |
+-----+
+-----+
(0 rows)

!ok
# As above, but for EXISTS
select *
from "scott".dept as d
where exists (
  select 0 from "scott".emp
  where deptno = deptno
  and ename = 'SMITH');
+--------+----------+--------+
| DEPTNO | DNAME    | LOC    |
+--------+----------+--------+
|     20 | RESEARCH | DALLAS |
+--------+----------+--------+
(1 row)

!ok
# [DRILL-5644]
select TJOIN1.RNUM, TJOIN1.C1,
  case when 10 in ( select C1 from ( values (1) ) T(C1) ) then 'yes' else 'no' end C3
from (
  values (0, 10, 15),
    (1, 20, 25),
    (2, cast(NULL as integer), 50)) TJOIN1 (RNUM, C1, C2);
