# Reset to default value 20
!set trimfields true

!use ansi
# [CALCITE-7379] LHS correlated variables are shadowed by nullable RHS outputs in LEFT JOIN
# Correlated scalar subquery with LEFT JOIN.
# The correlation variable (deptno) is used in the RHS of the join.
SELECT
    dname,
    (
        SELECT COUNT(empno)
        FROM emp e
        LEFT JOIN (
            SELECT * FROM emp e2 WHERE e2.deptno = deptno
        ) sub
        ON mgr = mgr
    ) as matched_subordinate_count
FROM dept d;
+------------+---------------------------+
| DNAME      | MATCHED_SUBORDINATE_COUNT |
+------------+---------------------------+
| ACCOUNTING |                         4 |
| OPERATIONS |                         0 |
| RESEARCH   |                         9 |
| SALES      |                        28 |
+------------+---------------------------+
(4 rows)

!ok

# Correlated scalar subquery with RIGHT JOIN.
# The correlation variable (deptno) is used in the LHS of the join.
SELECT
    dname,
    (
        SELECT COUNT(empno)
        FROM (
            SELECT * FROM emp e2 WHERE e2.deptno = deptno
        ) sub
        RIGHT JOIN emp e
        ON mgr = mgr
    ) as matched_subordinate_count
FROM dept d;
+------------+---------------------------+
| DNAME      | MATCHED_SUBORDINATE_COUNT |
+------------+---------------------------+
| ACCOUNTING |                         4 |
| OPERATIONS |                         0 |
| RESEARCH   |                         9 |
| SALES      |                        28 |
+------------+---------------------------+
(4 rows)

!ok

# Correlated scalar subquery with FULL JOIN.
# The correlation variable (deptno) is used in the LHS of the join.
SELECT
    dname,
    (
        SELECT COUNT(empno)
        FROM (
            SELECT * FROM emp e2 WHERE e2.deptno = deptno
        ) sub
        FULL JOIN emp e
        ON mgr = mgr
    ) as matched_subordinate_count
FROM dept d
order by dname;
+------------+---------------------------+
| DNAME      | MATCHED_SUBORDINATE_COUNT |
+------------+---------------------------+
| ACCOUNTING |                         5 |
| OPERATIONS |                         0 |
| RESEARCH   |                         9 |
| SALES      |                        28 |
+------------+---------------------------+
(4 rows)

!ok

