# [CALCITE-7272] Subqueries cannot be decorrelated if have set op
WITH
  customers(id, name, city) AS (
    VALUES
      (1, 'Alice', 'New York'),
      (2, 'Bob', 'San Francisco'),
      (3, 'Charlie', 'Los Angeles')
  ),
  orders(id, customer_id, total_amount) AS (
    VALUES
      (100, 1, 500.00),
      (101, 2, 150.00),
      (102, 1, 300.00)
  ),
  lineitems(id, order_id, product_name, price) AS (
    VALUES
      (1, 100, 'Laptop', 1000.00),
      (2, 100, 'Mouse', 20.00),
      (3, 100, 'Keyboard', 50.00),
      (4, 101, 'Monitor', 150.00)
  ),
  payments(id, customer_id, amount) AS (
    VALUES
      (1, 1, 200.00),
      (2, 1, 200.00),
      (3, 1, 100.00),
      (4, 2, 150.00)
  )
SELECT id, name
FROM customers c
WHERE EXISTS (
  SELECT 1
  FROM orders o
  WHERE customer_id = id
    AND (
      SELECT SUM(cnt)
      FROM (
        SELECT COUNT(*) AS cnt
        FROM lineitems li
        WHERE order_id = id
        UNION ALL
        SELECT COUNT(*) AS cnt
        FROM payments p
        WHERE customer_id = id
      ) AS union_sub
    ) > 5
);
+----+---------+
| ID | NAME    |
+----+---------+
|  1 | Alice   |
+----+---------+
(1 row)

!ok

