+---+---+---+
| 4 | 4 | 4 |
+---+---+---+
(1 row)

!ok

# [CALCITE-7320] AggregateProjectMergeRule throws AssertionError when Project maps multiple grouping keys to the same field
SELECT deptno,
       (SELECT SUM(cnt)
        FROM (
          SELECT COUNT(*) AS cnt
          FROM emp
          WHERE deptno = deptno
          GROUP BY GROUPING SETS ((deptno), ())
        ))
FROM dept;
