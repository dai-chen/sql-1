# match_query
# NOTE: pushdown-only function, tests verify spec format only
# group: basic
match_query('title'::str, 'opensearch'::str) = true::bool
match_query('content'::str, 'hello world'::str) = true::bool
match_query('description'::str, 'test query'::str) = true::bool
match_query('name'::str, 'John'::str) = true::bool

# group: null_handling
match_query(null::str, 'opensearch'::str) = null::bool
match_query('title'::str, null::str) = null::bool
match_query(null::str, null::str) = null::bool

# group: edge_cases
match_query('title'::str, ''::str) = true::bool
match_query(''::str, 'opensearch'::str) = true::bool
match_query('title'::str, 'a b c d e'::str) = true::bool

