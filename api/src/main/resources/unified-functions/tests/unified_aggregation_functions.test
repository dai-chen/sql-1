# percentile
# group: basic
percentile(50.0::fp64, 0.5::fp64) = 50.0::fp64
percentile(100.0::fp64, 1.0::fp64) = 100.0::fp64
percentile(0.0::fp64, 0.0::fp64) = 0.0::fp64
percentile(75.0::fp64, 0.25::fp64) = 75.0::fp64

# group: null_handling
percentile(null::fp64, 0.5::fp64) = null::fp64
percentile(50.0::fp64, null::fp64) = null::fp64
percentile(null::fp64, null::fp64) = null::fp64

# group: edge_cases
percentile(0.0::fp64, 0.0::fp64) = 0.0::fp64
percentile(0.0::fp64, 1.0::fp64) = 0.0::fp64
percentile(-100.0::fp64, 0.5::fp64) = -100.0::fp64

# percentile_approx
# group: basic
percentile_approx(50.0::fp64, 0.5::fp64) = 50.0::fp64
percentile_approx(100.0::fp64, 1.0::fp64) = 100.0::fp64
percentile_approx(0.0::fp64, 0.0::fp64) = 0.0::fp64
percentile_approx(75.0::fp64, 0.25::fp64) = 75.0::fp64

# group: null_handling
percentile_approx(null::fp64, 0.5::fp64) = null::fp64
percentile_approx(50.0::fp64, null::fp64) = null::fp64
percentile_approx(null::fp64, null::fp64) = null::fp64

# group: edge_cases
percentile_approx(0.0::fp64, 0.0::fp64) = 0.0::fp64
percentile_approx(0.0::fp64, 1.0::fp64) = 0.0::fp64
percentile_approx(-100.0::fp64, 0.5::fp64) = -100.0::fp64

