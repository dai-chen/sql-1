# take
# group: basic
take('hello'::str, 1::i32) = 'hello'::str
take('world'::str, 1::i32) = 'world'::str
take('test'::str, 1::i32) = 'test'::str
take('abc'::str, 1::i32) = 'abc'::str

# group: null_handling
take(null::str, 1::i32) = null::str
take('hello'::str, null::i32) = null::str
