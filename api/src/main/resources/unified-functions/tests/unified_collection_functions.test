# group: null_handling
array_join(null::str, ','::str) = null::str
array_join('["a","b"]'::str, null::str) = null::str
array_join(null::str, null::str) = null::str

# group: edge_cases
array_join('["a"]'::str, ','::str) = 'a'::str
array_join('[]'::str, ','::str) = ''::str
array_join('["a","b","c"]'::str, ''::str) = 'abc'::str
array_join('["hello","world"]'::str, ' '::str) = 'hello world'::str

