json_keys('{"a":1,"b":2,"c":3}'::str) = 'a,b,c'::str

# group: null_handling
json_keys(null::str) = null::str

# group: edge_cases
json_keys('[1,2,3]'::str) = null::str
json_keys('"hello"'::str) = null::str
