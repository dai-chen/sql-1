### SUBSTRAIT_SCALAR_TEST: v1.0
### SUBSTRAIT_INCLUDE: extension:org.opensearch:unified_ip_functions

# cidrmatch
# group: basic
cidrmatch('192.168.1.1'::str, '192.168.1.0/24'::str) = true::bool
cidrmatch('10.0.0.1'::str, '192.168.1.0/24'::str) = false::bool
cidrmatch('10.0.0.1'::str, '10.0.0.0/8'::str) = true::bool
cidrmatch('172.16.5.100'::str, '172.16.0.0/12'::str) = true::bool
cidrmatch('::1'::str, '::1/128'::str) = true::bool
cidrmatch('fe80::1'::str, 'fe80::/10'::str) = true::bool

# group: null_handling
cidrmatch(null::str, '192.168.1.0/24'::str) = null::bool
cidrmatch('192.168.1.1'::str, null::str) = null::bool
cidrmatch(null::str, null::str) = null::bool

# group: edge_cases
cidrmatch('not_an_ip'::str, '192.168.1.0/24'::str) = false::bool
cidrmatch('192.168.1.1'::str, 'bad_cidr'::str) = false::bool
cidrmatch(''::str, '10.0.0.0/8'::str) = false::bool
cidrmatch('192.168.1.1'::str, ''::str) = false::bool
cidrmatch('192.168.1.1'::str, '192.168.1.1/32'::str) = true::bool
cidrmatch('0.0.0.0'::str, '0.0.0.0/0'::str) = true::bool
cidrmatch('255.255.255.255'::str, '0.0.0.0/0'::str) = true::bool

# is_ipv4
# group: basic
is_ipv4('192.168.1.1'::str) = true::bool
is_ipv4('10.0.0.1'::str) = true::bool
is_ipv4('0.0.0.0'::str) = true::bool
is_ipv4('255.255.255.255'::str) = true::bool

# group: null_handling
is_ipv4(null::str) = null::bool

# group: edge_cases
is_ipv4(''::str) = false::bool
is_ipv4('not_an_ip'::str) = false::bool
is_ipv4('::1'::str) = false::bool
is_ipv4('256.1.1.1'::str) = false::bool
is_ipv4('1.2.3'::str) = false::bool
is_ipv4('1.2.3.4.5'::str) = false::bool
is_ipv4('192.168.1.1/24'::str) = false::bool

# is_ipv6
# group: basic
is_ipv6('::1'::str) = true::bool
is_ipv6('fe80::1'::str) = true::bool
is_ipv6('2001:0db8:85a3:0000:0000:8a2e:0370:7334'::str) = true::bool
is_ipv6('::'::str) = true::bool

# group: null_handling
is_ipv6(null::str) = null::bool

# group: edge_cases
is_ipv6(''::str) = false::bool
is_ipv6('not_an_ip'::str) = false::bool
is_ipv6('192.168.1.1'::str) = false::bool
is_ipv6('gggg::1'::str) = false::bool
is_ipv6('12345::1'::str) = false::bool
is_ipv6('2001:db8::g'::str) = false::bool

# ip_to_int
# group: basic
ip_to_int('0.0.0.0'::str) = 0::i64
ip_to_int('0.0.0.1'::str) = 1::i64
ip_to_int('192.168.1.1'::str) = 3232235777::i64
ip_to_int('255.255.255.255'::str) = 4294967295::i64
ip_to_int('10.0.0.1'::str) = 167772161::i64

# group: null_handling
ip_to_int(null::str) = null::i64

# group: edge_cases
ip_to_int(''::str) = null::i64
ip_to_int('not_an_ip'::str) = null::i64
ip_to_int('::1'::str) = null::i64
ip_to_int('256.0.0.1'::str) = null::i64
ip_to_int('1.2.3'::str) = null::i64

# int_to_ip
# group: basic
int_to_ip(0::i64) = '0.0.0.0'::str
int_to_ip(1::i64) = '0.0.0.1'::str
int_to_ip(3232235777::i64) = '192.168.1.1'::str
int_to_ip(4294967295::i64) = '255.255.255.255'::str
int_to_ip(167772161::i64) = '10.0.0.1'::str

# group: null_handling
int_to_ip(null::i64) = null::str

# group: edge_cases
int_to_ip(-1::i64) = null::str
int_to_ip(4294967296::i64) = null::str
int_to_ip(-100::i64) = null::str
int_to_ip(9999999999::i64) = null::str
int_to_ip(2147483647::i64) = '127.255.255.255'::str

# ip_version
# group: basic
ip_version('192.168.1.1'::str) = 4::i32
ip_version('10.0.0.1'::str) = 4::i32
ip_version('::1'::str) = 6::i32
ip_version('fe80::1'::str) = 6::i32
ip_version('2001:db8::1'::str) = 6::i32

# group: null_handling
ip_version(null::str) = null::i32

# group: edge_cases
ip_version(''::str) = null::i32
ip_version('not_an_ip'::str) = null::i32
ip_version('256.1.1.1'::str) = null::i32
ip_version('1.2.3'::str) = null::i32
ip_version('gggg::1'::str) = null::i32

# ip_prefix
# group: basic
ip_prefix('192.168.1.100'::str, 24::i32) = '192.168.1.0/24'::str
ip_prefix('10.0.0.1'::str, 8::i32) = '10.0.0.0/8'::str
ip_prefix('172.16.5.4'::str, 16::i32) = '172.16.0.0/16'::str
ip_prefix('2001:db8::1'::str, 32::i32) = '2001:db8::/32'::str
ip_prefix('192.168.1.1'::str, 32::i32) = '192.168.1.1/32'::str

# group: null_handling
ip_prefix(null::str, 24::i32) = null::str
ip_prefix('192.168.1.1'::str, null::i32) = null::str
ip_prefix(null::str, null::i32) = null::str

# group: edge_cases
ip_prefix(''::str, 24::i32) = null::str
ip_prefix('not_an_ip'::str, 24::i32) = null::str
ip_prefix('192.168.1.1'::str, -1::i32) = null::str
ip_prefix('192.168.1.1'::str, 33::i32) = null::str
ip_prefix('::1'::str, 129::i32) = null::str
ip_prefix('192.168.1.1'::str, 0::i32) = '0.0.0.0/0'::str
ip_prefix('::1'::str, 128::i32) = '::1/128'::str

# geoip
# group: basic
# Note: basic tests require an external GeoIP database; expected values are placeholders
geoip('8.8.8.8'::str, 'country_name'::str) = 'United States'::str
geoip('8.8.8.8'::str, 'city_name'::str) = 'Mountain View'::str
geoip('8.8.8.8'::str, 'region_name'::str) = 'California'::str

# group: null_handling
geoip(null::str, 'country_name'::str) = null::str
geoip('8.8.8.8'::str, null::str) = null::str
geoip(null::str, null::str) = null::str

# group: edge_cases
geoip(''::str, 'country_name'::str) = null::str
geoip('not_an_ip'::str, 'country_name'::str) = null::str
geoip('8.8.8.8'::str, 'unknown_field'::str) = null::str
geoip('192.168.1.1'::str, 'country_name'::str) = null::str
geoip('10.0.0.1'::str, 'city_name'::str) = null::str
geoip('256.1.1.1'::str, 'country_name'::str) = null::str
